{
  "cli": {
    "version": ">= 16.24.1",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": false,
      "distribution": "internal",
      "channel": "development",
      "ios": {
        "buildConfiguration": "Debug",
        "image": "macos-sequoia-15.6-xcode-26.0"
      },
      "node": "22.0.0",
      "env": {
        "EAS_SKIP_AUTO_FINGERPRINT": "1",
        "npm_config_legacy_peer_deps": "true"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "ios": {
        "image": "macos-sequoia-15.6-xcode-26.0"
      },
      "node": "22.0.0",
      "env": {
        "npm_config_legacy_peer_deps": "true"
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "ios": {
        "image": "macos-sequoia-15.6-xcode-26.0"
      },
      "node": "22.0.0",
      "env": {
        "npm_config_legacy_peer_deps": "true"
      }
    }
  },
  "submit": {
    "production": {}
  }
}